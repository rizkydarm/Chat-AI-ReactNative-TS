# ─── Dependencies ──────────────────────────────────────────────
node_modules/

# ─── Bun ───────────────────────────────────────────────────────
# NOTE: Do NOT ignore bun.lockb in version control! 
# It is essential for deterministic installs across CI and other developers.
# Uncomment the line below ONLY if you intentionally want to ignore it.
# bun.lockb

# ─── Build & Compilation ───────────────────────────────────────
dist/
out/
build/
*.tsbuildinfo

# ─── Turborepo ─────────────────────────────────────────────────
.turbo/

# ─── Expo / React Native ───────────────────────────────────────
.expo/
web-build/
# If you are using Expo Prebuild or bare workflow, 
# uncomment the lines below to ignore native generated folders:
# ios/
# android/

# Expo native credentials (never commit these)
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ─── Environment & Secrets ─────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*
pnpm-debug.log*

# ─── Testing & Coverage ────────────────────────────────────────
coverage/
.nyc_output/

# ─── IDE & Editors ─────────────────────────────────────────────
